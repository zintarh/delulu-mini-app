# ===========================================
# Delulu dApp Environment Variables
# ===========================================

NEXT_PUBLIC_SUBGRAPH_URL="https://api.studio.thegraph.com/query/1741533/delulu-prediction-market/0.01"

# --- App ---
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"



# --- Farcaster ---
NEXT_PUBLIC_FARCASTER_MINIAPP_URL=""
NEXT_PUBLIC_FARCASTER_HEADER=""
NEXT_PUBLIC_FARCASTER_PAYLOAD=""
NEXT_PUBLIC_FARCASTER_SIGNATURE=""

# --- Contract ---
NEXT_PUBLIC_DELULU_CONTRACT_MAINNET=""

# --- Pimlico (ERC-4337 gas sponsorship) ---
# Get your API key at https://dashboard.pimlico.io
# Create a sponsorship policy for Celo mainnet in the Pimlico dashboard
NEXT_PUBLIC_PIMLICO_API_KEY=""

# --- Resend (email reminders) ---
# Get your API key at https://resend.com/api-keys
# Set your from domain in Resend dashboard and update the `from` address in the cron route if needed.
RESEND_API_KEY=""

# --- Privy (required for login) ---
# Use one: PRIVY_APP_ID (server-only, passed to client by layout) or NEXT_PUBLIC_PRIVY_APP_ID (inlined in client).
# PRIVY_APP_ID=""
# NEXT_PUBLIC_PRIVY_APP_ID=""

# --- Privy session keys (optional; see apps/web/docs/PRIVY_SESSION_KEYS.md) ---
# Key quorum ID from Privy Dashboard (Wallet infrastructure > Authorization keys). Client uses this to add signer once.
# NEXT_PUBLIC_PRIVY_SIGNER_KEY_QUORUM_ID=""
# PRIVY_SIGNER_KEY_QUORUM_ID=""
# Server-only: private key for the app authorization key (P-256). Never expose to client.
# PRIVY_SIGNER_PRIVATE_KEY=""

# --- Admin Ops Login (optional, enables email/password admin access) ---
# When set, /api/admin/users requires a valid ops session cookie.
# ADMIN_OPS_EMAIL=""
# ADMIN_OPS_PASSWORD=""
# ADMIN_OPS_JWT_SECRET=""
