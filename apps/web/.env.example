# ===========================================
# Delulu dApp Environment Variables
# ===========================================

NEXT_PUBLIC_SUBGRAPH_URL="https://api.studio.thegraph.com/query/1741533/delulu-prediction-market/0.01"

# --- App ---
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development"

# --- Campaign leaderboard (optional) ---
# First Tuesday 00:00 UTC of the biweekly cadence (ISO 8601). Defaults to 2026-05-12.
# NEXT_PUBLIC_CAMPAIGN_EPOCH="2026-05-12T00:00:00.000Z"



# --- Farcaster ---
NEXT_PUBLIC_FARCASTER_MINIAPP_URL=""
NEXT_PUBLIC_FARCASTER_HEADER=""
NEXT_PUBLIC_FARCASTER_PAYLOAD=""
NEXT_PUBLIC_FARCASTER_SIGNATURE=""

# --- Contract ---
NEXT_PUBLIC_DELULU_CONTRACT_MAINNET=""
NEXT_PUBLIC_COMMUNITY_MARKET_V1_MAINNET=""

# --- Pimlico (ERC-4337 gas sponsorship) ---
# Get your API key at https://dashboard.pimlico.io
# Create a sponsorship policy for Celo mainnet in the Pimlico dashboard
NEXT_PUBLIC_PIMLICO_API_KEY=""

# --- Resend (email reminders) ---
# Get your API key at https://resend.com/api-keys
# Set your from domain in Resend dashboard and update the `from` address in the cron route if needed.
RESEND_API_KEY=""
# RESEND_FROM_EMAIL="Zinta from Delulu <reminders@staydelulu.xyz>"

# Vercel Cron (Production → Settings → Cron Jobs). Vercel sends Authorization: Bearer <secret>.
# CRON_SECRET=""
# PUSH_CRON_SECRET=""  # optional alias for manual curl /api/cron/email-reminders?secret=...

# --- Web3Auth (required for login) ---
# NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=""

# --- Supabase (server) ---
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""                 # Project Settings → API → anon public key
# SUPABASE_SERVICE_ROLE_KEY=""         # server-only; never expose to client

# --- Admin Ops Login (Supabase Auth) ---
# 1. Set SUPABASE_URL + SUPABASE_ANON_KEY above, then seed admin (password via env, never committed):
#    ADMIN_SEED_PASSWORD='your-password' pnpm seed:admin
# 2. Only allowlisted emails may use /admin (override with ADMIN_OPS_ALLOWED_EMAILS)
# Optional NEXT_PUBLIC_SUPABASE_* mirrors if you need Supabase Auth in the browser.
# ADMIN_OPS_ALLOWED_EMAILS="kateberryd@gmail.com"
# ADMIN_SEED_EMAIL="kateberryd@gmail.com"
# ADMIN_SEED_PASSWORD=""               # only for `pnpm seed:admin`, do not commit
