{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm turbo run build --filter=web",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/email-reminders",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/push-reminders",
      "schedule": "*/10 * * * *"
    }
  ]
}
